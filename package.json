{
  "name": "typescript-starter",
  "version": "1.0.0",
  "description": "A basic typescript app starter for newbies in 2022.",
  "main": "app.js",
  "scripts": {
    "start": "node dist/app",
    "build": "webpack --config webpack.config.js",
    "dev": "nodemon --exec ts-node-dev src/app",
    "prod": "node dist/app",
    "compile": "rimraf ./build && tsc",
    "start:dev": "nodemon",
    "lint": "eslint . --ext .ts"
  },
  "keywords": [],
